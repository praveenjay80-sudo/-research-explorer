# Free Semantic Scholar API key — raises rate limit from 1 req/s to 100 req/s
# Get yours at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# PDF Vector API key — adds PubMed, arXiv, Europe PMC, ERIC, Google Scholar to search
# Get 100 free credits at: https://app.pdfvector.com (2 credits per search)
# If not set, search falls back to Semantic Scholar + OpenAlex only
PDFVECTOR_API_KEY=
